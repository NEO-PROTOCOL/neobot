[
  {
    "id": "rule-dynamic-mint",
    "enabled": true,
    "on": "FLOWPAY:PAYMENT_RECEIVED",
    "dispatch": "FACTORY:MINT_REQUESTED",
    "transform": {
      "tokenId": "NEOFLW",
      "amount": "{{amount}}",
      "targetAddress": "{{payerId}}",
      "reason": "purchase",
      "refTransactionId": "{{orderId}}"
    },
    "priority": 10
  },
  {
    "id": "rule-notify-success",
    "enabled": true,
    "on": "FACTORY:MINT_CONFIRMED",
    "action": "notify_user",
    "params": {
      "message": "Success! Token minted. Tx: {{txId}}"
    }
  },
  {
    "id": "rule-node-offline-alert",
    "enabled": true,
    "on": "ECOSYSTEM:NODE_OFFLINE",
    "action": "notify_user",
    "params": {
      "message": "🚨 NODE OFFLINE: {{name}} ({{id}})\n🔗 {{url}}\n🕐 {{ts}}"
    },
    "priority": 99
  },
  {
    "id": "rule-node-recovered-alert",
    "enabled": true,
    "on": "ECOSYSTEM:NODE_RECOVERED",
    "action": "notify_user",
    "params": {
      "message": "✅ NODE RECUPERADO: {{name}} ({{id}})\n🔗 {{url}}\n🕐 {{ts}}"
    },
    "priority": 99
  }
]
